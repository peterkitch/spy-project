# Ignore distribution directories
dist/
build/

# Ignore cache files
.cache/

# Ignore organized cache and output directories
cache/
output/

# Ignore pickle and compressed files (if any remain in root)
*.pkl
*.pkl.gz
*.npz

# Ignore status and analysis JSON files (if any remain in root)
*_status.json
*_analysis.json

# QC backtest outputs
QC/Clone of Project 9/backtests/
QC/**/backtests/

# QC data directory
QC/data/

# Ignore log files
*.log

# Ignore run/session evidence written from project/
logs/

# Ignore batch files
*.bat

# Ignore results and status directories if applicable
results/
status/

# Ignore Excel files
*.xlsx
*.xls

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Python virtual environments
venv/
env/
.venv/
.env/

# Ignore MCP server container directory
mcp-server/

# Ignore JetBrains (IntelliJ/PyCharm) project configuration
.idea/
*.iml
misc.xml
.keep

# Ignore notebooks and large data files
*.ipynb
*.csv
*.zip

# Ignore all Markdown files except CLAUDE.md and md_library
*.md
!CLAUDE.md
!md_library/
!md_library/**/*.md
# Phase 6H-7: machine-readable operator command manifest lives
# under md_library/ as a JSON sibling to the runbook .md. Allow
# tracking JSON files under md_library specifically (operator
# documentation, not generated data); the global *.json ignore
# rule still catches everything else.
!md_library/**/*.json

# Global Ticker Library data files
global_ticker_library/data/*.db
global_ticker_library/data/*.db-*
global_ticker_library/data/*.txt
# Narrow exception: operator-curated V8 ticker list is tracked for review.
!global_ticker_library/data/V8_Ticker.txt
global_ticker_library/data/*.json
# Narrow exception: operator-curation artifacts (ban-lists, decision
# records). Tracked because they are review inputs for future
# ticker-builder runs, not generated data. The root *.json rule still
# catches everything else.
!global_ticker_library/curation/v8_removed_from_master_banlist.json

# Windows NUL device file
NUL

# Local machine-specific optimization files
local_optimization/

# Machine-specific Python scripts (if any remain in root)
*mkl*.py
*benchmark*.py
fix_*.py
verify_*.py
install_*.py
cleanup_*.py

# Test scripts directory:
# - Existing local stash subdirectories stay ignored (test_scripts/*/).
# - Top-level Python test files are trackable so Phase 0+ can land
#   parity/import-smoke/synthetic tests at test_scripts/*.py.
test_scripts/*/
!test_scripts/*.py

# Greenfield React MVP under project/frontend/ for the K=6 MTF
# board. The repo-root .gitignore globally ignores *.json,
# test_*.py, and the project-level rule above ignores *.md;
# narrowly re-include the frontend's JSON / package metadata /
# README docs / the committed fixture, plus the fixture-schema
# smoke test under test_scripts/shared/. The output/ ignore at
# the top of this file is unchanged.
!frontend/**/*.md
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json
!frontend/public/fixtures/k6_mtf_ranking.json
# Re-include the test_scripts/shared/ directory itself so the
# narrow fixture-schema smoke test is trackable, then re-ignore
# every other *.py in that directory (existing local-only audit
# scripts must remain untracked), then re-include only the
# specific test file.
!test_scripts/shared/
test_scripts/shared/*.py
!test_scripts/shared/test_k6_mtf_fixture_schema.py
!test_scripts/shared/test_react_publish_promote_k6_mtf_artifact.py
!test_scripts/shared/test_k6_mtf_validation_adapter.py

# React publish promotion-manifest sidecar (written by the
# operator-run helper at utils/react_publish/promote_k6_mtf_artifact.py
# per the publish/deploy contract). The repo-root *.json
# rule above otherwise hides it. The React app does NOT
# fetch this manifest; it lives next to the fixture as
# provenance only. No real manifest file is generated by
# the helper's introduction PR; this allow-list lets a future
# operator-run Option A refresh PR optionally track the
# generated manifest.
!frontend/public/fixtures/k6_mtf_ranking.promotion_manifest.json
