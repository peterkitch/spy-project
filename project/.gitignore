# Ignore distribution directories
dist/
build/

# Ignore cache files
.cache/

# Ignore organized cache and output directories
cache/
output/

# Ignore pickle and compressed files (if any remain in root)
*.pkl
*.pkl.gz
*.npz

# Ignore status and analysis JSON files (if any remain in root)
*_status.json
*_analysis.json

# QC backtest outputs
QC/Clone of Project 9/backtests/
QC/**/backtests/

# QC data directory
QC/data/

# Ignore log files
*.log

# Ignore batch files
*.bat

# Ignore results and status directories if applicable
results/
status/

# Ignore Excel files
*.xlsx
*.xls

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Python virtual environments
venv/
env/
.venv/
.env/

# Ignore MCP server container directory
mcp-server/

# Ignore JetBrains (IntelliJ/PyCharm) project configuration
.idea/
*.iml
misc.xml
.keep

# Ignore notebooks and large data files
*.ipynb
*.csv
*.zip

# Ignore all Markdown files except CLAUDE.md and md_library
*.md
!CLAUDE.md
!md_library/
!md_library/**/*.md

# Global Ticker Library data files
global_ticker_library/data/*.db
global_ticker_library/data/*.db-*
global_ticker_library/data/*.txt
global_ticker_library/data/*.json

# Windows NUL device file
NUL

# Local machine-specific optimization files
local_optimization/

# Machine-specific Python scripts (if any remain in root)
*mkl*.py
*benchmark*.py
fix_*.py
verify_*.py
install_*.py
cleanup_*.py

# Test scripts directory:
# - Existing local stash subdirectories stay ignored (test_scripts/*/).
# - Top-level Python test files are trackable so Phase 0+ can land
#   parity/import-smoke/synthetic tests at test_scripts/*.py.
test_scripts/*/
!test_scripts/*.py
