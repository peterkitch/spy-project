# Force LF line endings for Python files
*.py text eol=lf

# Auto-detect for other files
* text=auto

# Pin the K=6 MTF Phase 5 honest-validation report to LF so the
# PR #368 promotion helper's --phase5-sha256 reproduces the same
# canonical SHA across Windows and non-Windows checkouts. Without
# this pin, the * text=auto rule above renormalizes the file to
# CRLF on Windows checkout, producing a platform-dependent
# on-disk SHA that diverges from the canonical LF SHA recorded
# in the merged PR record and the operator brief.
md_library/shared/2026-06-01_K6_MTF_PHASE_5_HONEST_VALIDATION_REPORT.md text eol=lf

# Pin the scoped K=6 MTF Phase 5 honest-validation report family
# (e.g. *_REPORT_205.md) AND its paired report manifest to LF for the
# same reason: the v2 promotion gate binds manifest.report_sha256 to
# the raw on-disk report bytes, so the report file must hash to the
# canonical LF SHA on every platform. The * text=auto rule above would
# otherwise produce CRLF on Windows checkout and break the binding.
md_library/shared/*K6_MTF_PHASE_5_HONEST_VALIDATION_REPORT_*.md text eol=lf
md_library/shared/*K6_MTF_PHASE_5_HONEST_VALIDATION_REPORT_*.manifest.json text eol=lf

# Pin the committed public K=6 MTF fixture family to LF so promotion
# provenance hashes reproduce against the canonical Git blob bytes on
# every checkout platform.
frontend/public/fixtures/k6_mtf_ranking.json text eol=lf
frontend/public/fixtures/k6_mtf_ranking.promotion_manifest.json text eol=lf
frontend/public/fixtures/README.md text eol=lf
